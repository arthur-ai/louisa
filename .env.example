# Louisa environment variables
# Copy to .env.local and fill in. .env.local is gitignored.

# ── Shared ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── GitHub pipeline (Arthur Engine) ───────────────────────────────────────────
# PAT with repo read/write — used by lib/github.js for tag/PR/release calls.
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# "owner/repo" of the Louisa repo itself. Used by api/webhook.js and
# api/gitlab-webhook.js to dispatch the release-notes GitHub Action.
LOUISA_GITHUB_REPO=

# GitHub App credentials — used to mint installation tokens for repository_dispatch
# and the release-status endpoint. See lib/github-app.js.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
# PEM private key. Either literal newlines (wrap in quotes) or \n-escaped.
GITHUB_APP_PRIVATE_KEY=

# ── GitLab pipeline (Arthur Platform) ─────────────────────────────────────────
GITLAB_TOKEN=
# Token verified against the x-gitlab-token header in api/gitlab-webhook.js.
GITLAB_WEBHOOK_SECRET=
GITLAB_PROJECT_ID=

# Optional: second (frontend) project. When set, commits and MRs from both
# projects are merged into one set of release notes.
GITLAB_SCOPE_PROJECT_ID=

# Suffix that identifies production tags. Must be non-empty or it matches every tag.
GITLAB_PROD_TAG_SUFFIX=-success-aws-prod-platform

# ── Tracing (optional — silently skipped if absent) ───────────────────────────
ARTHUR_BASE_URL=
ARTHUR_API_KEY=
ARTHUR_TASK_ID=

# ── Notifications (optional) ──────────────────────────────────────────────────
# Outbound release notifications via Slack/Teams Incoming Webhooks (one-way).
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# ── Interactive Slack bot (api/slack-events.js) ───────────────────────────────
# @Louisa mention → cross-version release-notes summary, posted in-thread.
# Add these to the SAME Slack App that backs SLACK_WEBHOOK_URL — no new app needed.
# Enable Event Subscriptions (app_mention) and add bot scopes app_mentions:read + chat:write.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ── Monthly changelog publish (scripts/publish-changelog.js) ──────────────────
README_API_KEY=
README_AUTHOR_ID=
